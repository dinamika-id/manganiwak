<?xml version="1.0" encoding="utf-8"?>
<!--
    Pre-Android 12 (API < 31) Auto Backup rules.
    Referenced by android:fullBackupContent in AndroidManifest.xml.
    Since allowBackup="false" is set, this provides an explicit exclusion declaration
    for compliance with Play Console backup policy on older API levels.
-->
<full-backup-content>
    <!-- Exclude all app data from Auto Backup (game state is local-only) -->
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
